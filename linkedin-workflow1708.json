      "notes": "Service: company_domain_to_employees\nResponse: $json.result (array of employee objects)\nPurpose: Gets list of decision makers filtered by seniority\nSeniority Filter: director,vp,cxo,owner,partner\nGet API key: https://linkfinderai.com/?ref=reddit"
    },
    {
      "parameters": {
        "jsCode": "const companyData = $('Merge Company Data').item.json;\nconst employees = $input.first().json.result || [];\n\nconst output = [];\n\nif (Array.isArray(employees) && employees.length > 0) {\n  for (const emp of employees) {\n    output.push({\n      json: {\n        company_name: companyData.company_name,\n        website: companyData.website,\n        linkedin_url: companyData.linkedin_url,\n        industry: companyData.industry,\n        company_size: companyData.company_size,\n        employee_name: emp.name || emp.fullName || 'N/A',\n        employee_title: emp.title || emp.jobTitle || 'N/A',\n        employee_email: emp.email || 'N/A',\n        employee_linkedin: emp.linkedin || emp.linkedinUrl || emp.profile_url || 'N/A'\n      }\n    });\n  }\n} else {\n  output.push({\n    json: {\n      company_name: companyData.company_name,\n      website: companyData.website,\n      linkedin_url: companyData.linkedin_url,\n      industry: companyData.industry,\n      company_size: companyData.company_size,\n      employee_name: 'No decision makers found',\n      employee_title: 'N/A',\n      employee_email: 'N/A',\n      employee_linkedin: 'N/A'\n    }\n  });\n}\n\nreturn output;"
      },
